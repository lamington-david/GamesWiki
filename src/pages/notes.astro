---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="My Notes — GamesWiki">
  <div style="max-width: 720px; margin: 0 auto; padding: 2rem 1.5rem;">

    <div style="margin-bottom: 2rem; display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
      <div>
        <h1 style="font-size: 1.75rem; font-weight: 800; color: #f1f5f9; letter-spacing: -0.04em; margin-bottom: 0.375rem;">My Notes</h1>
        <p id="notes-stats" style="font-size: 0.875rem; color: #64748b;">Loading...</p>
      </div>
      <button id="share-btn" style="display: flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1.25rem; background-color: #0891b2; color: white; border: none; border-radius: 0.5rem; font-size: 0.9rem; font-weight: 600; cursor: pointer; white-space: nowrap;">
        Share to Claude
      </button>
    </div>

    <!-- Search -->
    <input
      id="notes-search"
      type="text"
      placeholder="Search notes..."
      style="width: 100%; box-sizing: border-box; padding: 0.625rem 1rem; background-color: #0f172a; border: 1px solid #1e293b; border-radius: 0.5rem; color: #f1f5f9; font-size: 0.9375rem; margin-bottom: 1rem; outline: none;"
    />

    <!-- Tag cloud -->
    <div id="tag-cloud" style="display: flex; flex-wrap: wrap; gap: 0.375rem; margin-bottom: 1.5rem;"></div>

    <!-- Notes list -->
    <div id="notes-list" style="display: flex; flex-direction: column; gap: 0.875rem;"></div>

    <div id="notes-empty" style="display: none; text-align: center; padding: 4rem 0; color: #374151;">
      <p style="font-size: 1rem; margin-bottom: 0.375rem;">No notes yet.</p>
      <p style="font-size: 0.875rem;">Tap ✏️ on any resource card to start taking notes.</p>
    </div>

    <div id="copy-feedback" style="display: none; position: fixed; bottom: 1.25rem; left: 50%; transform: translateX(-50%); background-color: #1e293b; border: 1px solid #334155; color: #94a3b8; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 0.875rem; z-index: 60;">
      Copied to clipboard
    </div>
  </div>

  <script>
    import { getNotes, deleteNote, getAllTags, formatForClaude } from '../scripts/notes';

    let activeTag: string | null = null;
    let searchQuery = '';

    function render() {
      const notes = getNotes();
      const entries = Object.entries(notes).filter(([, n]) => n.note.trim());
      const list = document.getElementById('notes-list')!;
      const empty = document.getElementById('notes-empty')!;
      const stats = document.getElementById('notes-stats')!;
      const tagCloud = document.getElementById('tag-cloud')!;

      // Stats
      const gameCount = new Set(entries.map(([, n]) => n.gameSlug)).size;
      stats.textContent = `${entries.length} note${entries.length !== 1 ? 's' : ''} across ${gameCount} game${gameCount !== 1 ? 's' : ''}`;

      // Tag cloud
      const tagCounts = getAllTags(notes);
      const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
      tagCloud.innerHTML = tags.length ? [
        `<button data-tag-all style="padding:0.2rem 0.625rem;border-radius:9999px;font-size:0.75rem;font-weight:500;cursor:pointer;border:1px solid ${!activeTag ? '#0891b2' : '#1e293b'};background:${!activeTag ? 'rgba(8,145,178,0.2)' : 'transparent'};color:${!activeTag ? '#38bdf8' : '#64748b'};">All</button>`,
        ...tags.map(([t, c]) => `<button data-tag="${t}" style="padding:0.2rem 0.625rem;border-radius:9999px;font-size:0.75rem;font-weight:500;cursor:pointer;border:1px solid ${activeTag===t ? '#0891b2' : '#1e293b'};background:${activeTag===t ? 'rgba(8,145,178,0.2)' : 'transparent'};color:${activeTag===t ? '#38bdf8' : '#64748b'};">#${t} <span style="opacity:0.6;">${c}</span></button>`)
      ].join('') : '';

      // Filter
      const filtered = entries.filter(([, n]) => {
        const matchTag = !activeTag || n.tags.includes(activeTag);
        const q = searchQuery.toLowerCase();
        const matchSearch = !q || n.note.toLowerCase().includes(q) || n.resourceTitle.toLowerCase().includes(q) || n.gameName.toLowerCase().includes(q) || n.tags.some(t => t.includes(q));
        return matchTag && matchSearch;
      }).sort((a, b) => b[1].updatedAt - a[1].updatedAt);

      if (filtered.length === 0) { list.innerHTML = ''; empty.style.display = 'block'; return; }
      empty.style.display = 'none';

      // Group by game
      const byGame: Record<string, typeof filtered> = {};
      filtered.forEach(e => { (byGame[e[1].gameSlug] ??= []).push(e); });

      list.innerHTML = Object.values(byGame).sort((a, b) => b[0][1].updatedAt - a[0][1].updatedAt).map(gameNotes => {
        const gameName = gameNotes[0][1].gameName;
        const gameSlug = gameNotes[0][1].gameSlug;
        return `
          <div>
            <a href="/games/${gameSlug}" style="display:inline-block;font-size:0.8rem;font-weight:600;color:#64748b;text-decoration:none;margin-bottom:0.625rem;letter-spacing:0.03em;text-transform:uppercase;">${gameName}</a>
            <div style="display:flex;flex-direction:column;gap:0.625rem;">
              ${gameNotes.map(([url, n]) => `
                <div style="background-color:#0f172a;border:1px solid #1e293b;border-left:3px solid #0891b2;border-radius:0.5rem;padding:0.875rem;">
                  <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.5rem;margin-bottom:0.5rem;">
                    <span style="font-size:0.7rem;color:#64748b;background:#1e293b;padding:0.1rem 0.4rem;border-radius:9999px;">${n.resourceType.replace(/_/g,' ')}</span>
                    <div style="display:flex;gap:0.75rem;flex-shrink:0;">
                      <button class="edit-note-btn" data-url="${url}" data-title="${n.resourceTitle.replace(/"/g,'&quot;')}" data-game-slug="${n.gameSlug}" data-game-name="${n.gameName.replace(/"/g,'&quot;')}" data-type="${n.resourceType}" style="font-size:0.75rem;color:#818cf8;background:none;border:none;cursor:pointer;padding:0;">Edit</button>
                    </div>
                  </div>
                  <p style="font-size:0.8rem;color:#94a3b8;margin-bottom:0.375rem;">${n.resourceTitle}</p>
                  <p style="font-size:0.875rem;color:#e2e8f0;line-height:1.6;white-space:pre-wrap;">${n.note.replace(/</g,'&lt;')}</p>
                  ${n.tags.length ? `<div style="display:flex;flex-wrap:wrap;gap:0.375rem;margin-top:0.5rem;">${n.tags.map(t=>`<span style="font-size:0.7rem;color:#38bdf8;background:rgba(14,165,233,0.1);border:1px solid rgba(14,165,233,0.25);padding:0.1rem 0.4rem;border-radius:9999px;">#${t}</span>`).join('')}</div>` : ''}
                  <p style="font-size:0.7rem;color:#334155;margin-top:0.5rem;">${new Date(n.updatedAt).toLocaleDateString()}</p>
                </div>
              `).join('')}
            </div>
          </div>
        `;
      }).join('');

      // Edit buttons
      document.querySelectorAll<HTMLElement>('.edit-note-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.dispatchEvent(new CustomEvent('open-note-drawer', {
            detail: {
              url: btn.dataset.url,
              title: btn.dataset.title,
              gameSlug: btn.dataset.gameSlug,
              gameName: btn.dataset.gameName,
              type: btn.dataset.type,
            }
          }));
        });
      });

      // Tag buttons
      tagCloud.querySelectorAll<HTMLElement>('[data-tag]').forEach(btn => {
        btn.addEventListener('click', () => { activeTag = btn.dataset.tag!; render(); });
      });
      const allBtn = tagCloud.querySelector<HTMLElement>('[data-tag-all]');
      allBtn?.addEventListener('click', () => { activeTag = null; render(); });
    }

    // Share to Claude
    document.getElementById('share-btn')!.addEventListener('click', async () => {
      const text = formatForClaude(getNotes());
      if (navigator.share) {
        try { await navigator.share({ text, title: 'GamesWiki Notes' }); } catch {}
      } else {
        await navigator.clipboard.writeText(text);
        const fb = document.getElementById('copy-feedback')!;
        fb.style.display = 'block';
        setTimeout(() => { fb.style.display = 'none'; }, 2500);
      }
    });

    // Search
    document.getElementById('notes-search')!.addEventListener('input', e => {
      searchQuery = (e.target as HTMLInputElement).value;
      render();
    });

    window.addEventListener('notes-changed', render);
    render();
  </script>
</BaseLayout>

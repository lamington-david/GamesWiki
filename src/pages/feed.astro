---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ResourceCard from '../components/ResourceCard.astro';

const allGames = await getCollection('games');
const sorted = allGames.sort((a, b) => b.data.playtime - a.data.playtime);

const feedItems = sorted.flatMap(game =>
  game.data.resources.map(r => ({
    ...r,
    gameName: game.data.title,
    gameSlug: game.id,
  }))
);

const totalResources = feedItems.length;
const allUrls = feedItems.map(r => r.url);
---

<BaseLayout title="Feed — GamesWiki">
  <div style="max-width: 720px; margin: 0 auto; padding: 2rem 1.5rem;">

    <!-- Header -->
    <div style="margin-bottom: 2rem;">
      <h1 style="font-size: 1.75rem; font-weight: 800; color: #f1f5f9; letter-spacing: -0.04em; margin-bottom: 0.375rem;">Reading Feed</h1>
      <p id="feed-stats" style="font-size: 0.875rem; color: #64748b;">
        {totalResources} resources
      </p>
    </div>

    <!-- Filter bar -->
    <div style="display: flex; gap: 0.5rem; margin-bottom: 1.75rem; flex-wrap: wrap; align-items: center;">
      <button id="filter-all" class="feed-filter" data-filter="all"
        style="padding: 0.375rem 1rem; border-radius: 9999px; font-size: 0.8125rem; font-weight: 500; border: 1px solid #4f46e5; background-color: #4f46e5; color: white; cursor: pointer;">
        All
      </button>
      <button id="filter-unread" class="feed-filter" data-filter="unread"
        style="padding: 0.375rem 1rem; border-radius: 9999px; font-size: 0.8125rem; font-weight: 500; border: 1px solid #1e293b; background-color: transparent; color: #94a3b8; cursor: pointer;">
        Unread <span id="unread-count" style="background-color: #4f46e5; color: white; font-size: 0.7rem; padding: 0.1rem 0.4rem; border-radius: 9999px; margin-left: 0.25rem;">—</span>
      </button>
      <button id="filter-read" class="feed-filter" data-filter="read"
        style="padding: 0.375rem 1rem; border-radius: 9999px; font-size: 0.8125rem; font-weight: 500; border: 1px solid #1e293b; background-color: transparent; color: #94a3b8; cursor: pointer;">
        Read
      </button>
      <div style="width: 1px; height: 1.25rem; background-color: #1e293b; margin: 0 0.125rem;"></div>
      <button id="filter-readable" data-readable="false"
        style="padding: 0.375rem 1rem; border-radius: 9999px; font-size: 0.8125rem; font-weight: 500; border: 1px solid #1e293b; background-color: transparent; color: #94a3b8; cursor: pointer; display: flex; align-items: center; gap: 0.375rem;">
        📖 <span>Text only</span>
      </button>
    </div>

    <!-- Feed list -->
    <div id="feed-list" style="display: flex; flex-direction: column; gap: 0.75rem;">
      {feedItems.map((item) => (
        <div class="feed-item" data-url={item.url} data-game-slug={item.gameSlug} data-resource-type={item.type}>
          <ResourceCard resource={item} gameName={item.gameName} gameSlug={item.gameSlug} />
        </div>
      ))}
    </div>

    <div id="feed-empty" style="display: none; text-align: center; padding: 4rem 0; color: #374151;">
      <p style="font-size: 1rem; margin-bottom: 0.5rem;">Nothing here yet.</p>
      <p style="font-size: 0.875rem;">Open some resources and they'll appear here.</p>
    </div>
  </div>

  <script define:vars={{ allUrls, totalResources }}>
    const READS_KEY = 'gw:reads';
    function getReads() {
      try { return JSON.parse(localStorage.getItem(READS_KEY) || '{}'); }
      catch { return {}; }
    }

    let currentFilter = 'all';
    let textOnly = false;
    const TEXT_TYPES = new Set(['article', 'postmortem', 'interview']);

    function applyFilter() {
      const reads = getReads();
      const items = document.querySelectorAll('.feed-item');
      let visibleCount = 0;

      items.forEach(item => {
        const url = item.dataset.url;
        const type = item.dataset.resourceType || '';
        const isRead = !!reads[url];
        const matchesRead = currentFilter === 'all' ||
                            (currentFilter === 'unread' && !isRead) ||
                            (currentFilter === 'read' && isRead);
        const matchesType = !textOnly || TEXT_TYPES.has(type);
        const show = matchesRead && matchesType;
        item.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });

      document.getElementById('feed-empty').style.display = visibleCount === 0 ? 'block' : 'none';
    }

    function updateStats() {
      const reads = getReads();
      const readCount = allUrls.filter(url => reads[url]).length;
      const unreadCount = totalResources - readCount;

      document.getElementById('feed-stats').textContent =
        `${totalResources} resources · ${readCount} read · ${unreadCount} unread`;
      document.getElementById('unread-count').textContent = String(unreadCount);
    }

    function updateReadStates() {
      const reads = getReads();
      document.querySelectorAll('[data-resource-url]').forEach(card => {
        const url = card.dataset.resourceUrl;
        const isRead = !!reads[url];
        const unreadBorder = card.dataset.unreadBorder || '#4f46e5';
        const check = card.querySelector('.read-check');

        if (isRead) {
          card.style.opacity = '0.45';
          card.style.borderLeftColor = '#1f2937';
          if (check) check.style.display = 'inline';
        } else {
          card.style.opacity = '1';
          card.style.borderLeftColor = unreadBorder;
          if (check) check.style.display = 'none';
        }
      });
    }

    // Read-state filter buttons
    document.querySelectorAll('.feed-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        currentFilter = btn.dataset.filter;
        document.querySelectorAll('.feed-filter').forEach(b => {
          b.style.backgroundColor = 'transparent';
          b.style.color = '#94a3b8';
          b.style.borderColor = '#1e293b';
        });
        btn.style.backgroundColor = '#4f46e5';
        btn.style.color = 'white';
        btn.style.borderColor = '#4f46e5';
        applyFilter();
      });
    });

    // Text-only toggle
    const readableBtn = document.getElementById('filter-readable')!;
    readableBtn.addEventListener('click', () => {
      textOnly = !textOnly;
      readableBtn.dataset.readable = String(textOnly);
      readableBtn.style.backgroundColor = textOnly ? 'rgba(5,150,105,0.15)' : 'transparent';
      readableBtn.style.color = textOnly ? '#6ee7b7' : '#94a3b8';
      readableBtn.style.borderColor = textOnly ? '#065f46' : '#1e293b';
      applyFilter();
    });

    // Mark as read on click (listen for storage changes too so other tabs stay in sync)
    document.addEventListener('click', e => {
      const card = e.target.closest('[data-resource-url]');
      if (!card) return;
      const url = card.dataset.resourceUrl;
      const reads = getReads();
      if (!reads[url]) {
        reads[url] = Date.now();
        localStorage.setItem(READS_KEY, JSON.stringify(reads));
        updateReadStates();
        updateStats();
        // Re-apply filter after a short delay so user sees the card before it disappears
        if (currentFilter !== 'all') {
          setTimeout(applyFilter, 800);
        }
      }
    });

    window.addEventListener('storage', e => {
      if (e.key === READS_KEY) { updateReadStates(); updateStats(); applyFilter(); }
    });

    // --- Daily pseudo-random shuffle ---
    function mulberry32(seed) {
      return () => {
        seed |= 0; seed = seed + 0x6D2B79F5 | 0;
        let t = Math.imul(seed ^ seed >>> 15, 1 | seed);
        t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
        return ((t ^ t >>> 14) >>> 0) / 4294967296;
      };
    }
    function hashStr(str) {
      let h = 0;
      for (let i = 0; i < str.length; i++) h = Math.imul(31, h) + str.charCodeAt(i) | 0;
      return h;
    }
    function seededShuffle(arr, rand) {
      const a = [...arr];
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(rand() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    function applyDailyOrder() {
      const container = document.getElementById('feed-list');
      if (!container) return;

      const rand = mulberry32(hashStr(new Date().toDateString()));
      const items = Array.from(container.querySelectorAll('.feed-item'));

      // Group by game slug
      const byGame = new Map();
      items.forEach(item => {
        const slug = item.dataset.gameSlug || 'unknown';
        if (!byGame.has(slug)) byGame.set(slug, []);
        byGame.get(slug).push(item);
      });

      // Shuffle game order with daily seed, then interleave round-robin
      const games = seededShuffle([...byGame.keys()], rand);
      const maxLen = Math.max(...games.map(g => byGame.get(g).length));
      const ordered = [];
      for (let i = 0; i < maxLen; i++) {
        for (const game of games) {
          const gameItems = byGame.get(game);
          if (i < gameItems.length) ordered.push(gameItems[i]);
        }
      }

      ordered.forEach(item => container.appendChild(item));
    }

    // Init
    applyDailyOrder();
    updateReadStates();
    updateStats();
    applyFilter();
  </script>
</BaseLayout>

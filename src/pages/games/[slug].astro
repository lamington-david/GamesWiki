---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceCard from '../../components/ResourceCard.astro';

export async function getStaticPaths() {
  const games = await getCollection('games');
  return games.map(game => ({ params: { slug: game.id }, props: { game } }));
}

const { game } = Astro.props;
const { Content } = await render(game);

const { title, developer, publisher, year, genres, playtime, steam_rating, description, resources, design_tags } = game.data;

const grouped = {
  gdc_talk:    resources.filter(r => r.type === 'gdc_talk'),
  interview:   resources.filter(r => r.type === 'interview'),
  postmortem:  resources.filter(r => r.type === 'postmortem'),
  article:     resources.filter(r => r.type === 'article'),
  video:       resources.filter(r => r.type === 'video'),
  documentary: resources.filter(r => r.type === 'documentary'),
  podcast:     resources.filter(r => r.type === 'podcast'),
};

const sectionLabels: Record<string, string> = {
  gdc_talk: 'GDC Talks',
  interview: 'Interviews',
  postmortem: 'Postmortems',
  article: 'Articles & Essays',
  video: 'Videos',
  documentary: 'Documentaries',
  podcast: 'Podcasts',
};

const ratingColor = steam_rating >= 95 ? '#4ade80' : steam_rating >= 90 ? '#a3e635' : steam_rating >= 80 ? '#facc15' : '#f87171';
---

<BaseLayout title={`${title} — GamesWiki`} description={description}>
  <div style="max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem;">

    <!-- Back -->
    <a href="/" style="display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.8125rem; color: #64748b; text-decoration: none; margin-bottom: 2rem; transition: color 0.15s;"
       onmouseover="this.style.color='#94a3b8'" onmouseout="this.style.color='#64748b'">
      ← All Games
    </a>

    <!-- Game Header -->
    <div style="margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid #1e293b;">
      <div style="display: flex; flex-wrap: wrap; gap: 0.375rem; margin-bottom: 0.875rem;">
        {genres.map(g => (
          <span style="display: inline-flex; align-items: center; padding: 0.15rem 0.625rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; background-color: #1e293b; color: #94a3b8; border: 1px solid #334155;">
            {g}
          </span>
        ))}
      </div>

      <h1 style="font-size: 2rem; font-weight: 800; color: #f1f5f9; letter-spacing: -0.04em; margin-bottom: 0.375rem;">
        {title}
      </h1>

      <div style="display: flex; flex-wrap: wrap; gap: 1.25rem; align-items: center; margin-bottom: 1rem;">
        <span style="font-size: 0.875rem; color: #64748b;">{developer}{publisher && publisher !== developer ? ` · Published by ${publisher}` : ''} · {year}</span>
        <span style={`font-size: 0.875rem; font-weight: 600; color: ${ratingColor};`}>{steam_rating.toFixed(1)}% Steam Rating</span>
        <span style="font-size: 0.875rem; color: #64748b;">{playtime}h played</span>
      </div>

      <p style="font-size: 0.9375rem; color: #94a3b8; line-height: 1.7; max-width: 680px;">{description}</p>

      {design_tags.length > 0 && (
        <div style="margin-top: 1rem; display: flex; flex-wrap: wrap; gap: 0.375rem; align-items: center;">
          <span style="font-size: 0.75rem; color: #475569;">Design focus:</span>
          {design_tags.map(tag => (
            <span style="display: inline-flex; align-items: center; padding: 0.15rem 0.625rem; border-radius: 9999px; font-size: 0.7rem; font-weight: 500; background-color: rgba(79,70,229,0.15); color: #a5b4fc; border: 1px solid rgba(99,102,241,0.3);">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>

    <!-- Resources filter -->
    {resources.length > 0 && (
      <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
        <button class="res-filter active-res-filter" data-filter="all"
          style="padding: 0.3rem 0.875rem; border-radius: 9999px; font-size: 0.8rem; font-weight: 500; border: 1px solid #4f46e5; background-color: #4f46e5; color: white; cursor: pointer;">
          All ({resources.length})
        </button>
        <button class="res-filter" data-filter="unread"
          style="padding: 0.3rem 0.875rem; border-radius: 9999px; font-size: 0.8rem; font-weight: 500; border: 1px solid #1e293b; background-color: transparent; color: #94a3b8; cursor: pointer;">
          Unread
        </button>
      </div>
    )}

    <!-- Resources by section -->
    {resources.length === 0 && (
      <div style="text-align: center; padding: 3rem 0; color: #374151; border: 1px dashed #1e293b; border-radius: 0.5rem;">
        <p style="font-size: 0.9375rem;">No resources yet for this game.</p>
        <p style="font-size: 0.8125rem; margin-top: 0.25rem;">Resources will be added over time.</p>
      </div>
    )}

    {Object.entries(grouped).map(([type, items]) =>
      items.length > 0 && (
        <section style="margin-bottom: 2.5rem;">
          <h2 style="font-size: 1.125rem; font-weight: 600; color: #e2e8f0; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
            {sectionLabels[type]}
            <span style="font-size: 0.75rem; font-weight: 400; color: #475569; background-color: #1e293b; padding: 0.1rem 0.5rem; border-radius: 9999px;">{items.length}</span>
          </h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 0.75rem;">
            {items.map(resource => <ResourceCard resource={resource} gameSlug={game.id} gameName={title} />)}
          </div>
        </section>
      )
    )}

    <!-- Design Notes (from markdown body) -->
    {game.body.trim().length > 0 && (
      <section style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid #1e293b;">
        <h2 style="font-size: 1.125rem; font-weight: 600; color: #e2e8f0; margin-bottom: 1.25rem;">Design Notes</h2>
        <div class="prose" style="color: #94a3b8; line-height: 1.8; font-size: 0.9375rem; max-width: 700px;">
          <Content />
        </div>
      </section>
    )}

    <!-- My Notes (client-side rendered) -->
    <section id="my-notes-section" style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid #1e293b; display: none;">
      <h2 style="font-size: 1.125rem; font-weight: 600; color: #e2e8f0; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
        My Notes
        <span id="my-notes-count" style="font-size: 0.75rem; font-weight: 400; color: #475569; background-color: #1e293b; padding: 0.1rem 0.5rem; border-radius: 9999px;"></span>
      </h2>
      <div id="my-notes-list" style="display: flex; flex-direction: column; gap: 0.75rem;"></div>
    </section>
  </div>

  <script>
    const READS_KEY = 'gw:reads';
    function getReads() {
      try { return JSON.parse(localStorage.getItem(READS_KEY) || '{}'); } catch { return {}; }
    }

    let currentFilter = 'all';

    function applyFilter() {
      const reads = getReads();
      document.querySelectorAll<HTMLElement>('[data-resource-url]').forEach(card => {
        const url = card.dataset.resourceUrl!;
        const isRead = !!reads[url];
        const show = currentFilter === 'all' || (currentFilter === 'unread' && !isRead);
        const wrapper = card.closest<HTMLElement>('.resource-wrapper');
        if (wrapper) wrapper.style.display = show ? '' : 'none';
      });
      // Hide empty sections
      document.querySelectorAll<HTMLElement>('section').forEach(sec => {
        const visible = Array.from(sec.querySelectorAll('.resource-wrapper')).some(w => (w as HTMLElement).style.display !== 'none');
        sec.style.display = (sec.querySelectorAll('.resource-wrapper').length > 0 && !visible) ? 'none' : '';
      });
    }

    function updateUnreadBtn() {
      const reads = getReads();
      const cards = document.querySelectorAll<HTMLElement>('[data-resource-url]');
      const unread = Array.from(cards).filter(c => !reads[c.dataset.resourceUrl!]).length;
      const btn = document.querySelector<HTMLElement>('[data-filter="unread"]');
      if (btn) btn.textContent = `Unread (${unread})`;
    }

    document.querySelectorAll<HTMLElement>('.res-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        currentFilter = btn.dataset.filter!;
        document.querySelectorAll<HTMLElement>('.res-filter').forEach(b => {
          b.style.backgroundColor = 'transparent';
          b.style.color = '#94a3b8';
          b.style.borderColor = '#1e293b';
        });
        btn.style.backgroundColor = '#4f46e5';
        btn.style.color = 'white';
        btn.style.borderColor = '#4f46e5';
        applyFilter();
      });
    });

    // Wrap each resource card for show/hide without breaking layout
    document.querySelectorAll<HTMLElement>('[data-resource-url]').forEach(card => {
      const wrapper = document.createElement('div');
      wrapper.className = 'resource-wrapper';
      card.parentNode!.insertBefore(wrapper, card);
      wrapper.appendChild(card);
    });

    document.addEventListener('DOMContentLoaded', () => { updateUnreadBtn(); applyFilter(); renderMyNotes(); });
    window.addEventListener('storage', e => { if (e.key === READS_KEY) { updateUnreadBtn(); applyFilter(); } });
    window.addEventListener('notes-changed', renderMyNotes);
  </script>

  <!-- Pass game data via data attributes so the module script can read it -->
  <div id="game-meta" data-game-id={game.id} data-game-title={title} style="display:none;"></div>

  <script>
    import { getNotes } from '../../scripts/notes';

    const meta = document.getElementById('game-meta');
    const gameId = meta?.dataset.gameId ?? '';
    const gameTitle = meta?.dataset.gameTitle ?? '';

    function renderMyNotes() {
      const notes = getNotes();
      const section = document.getElementById('my-notes-section');
      const list = document.getElementById('my-notes-list');
      const count = document.getElementById('my-notes-count');
      if (!section || !list) return;

      const gameNotes = Object.entries(notes)
        .filter(([, n]) => n.gameSlug === gameId && n.note.trim())
        .sort((a, b) => b[1].updatedAt - a[1].updatedAt);

      if (gameNotes.length === 0) { section.style.display = 'none'; return; }

      section.style.display = 'block';
      if (count) count.textContent = String(gameNotes.length);

      list.innerHTML = gameNotes.map(([url, n]) => `
        <div style="background-color:#0f172a;border:1px solid #1e293b;border-left:3px solid #0891b2;border-radius:0.5rem;padding:0.875rem;">
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.5rem;margin-bottom:0.5rem;">
            <span style="font-size:0.75rem;color:#64748b;background-color:#1e293b;padding:0.125rem 0.5rem;border-radius:9999px;white-space:nowrap;">${n.resourceType.replace(/_/g,' ')}</span>
            <button class="my-note-edit-btn"
              data-url="${url}" data-title="${n.resourceTitle.replace(/"/g,'&quot;')}"
              data-game-slug="${gameId}" data-game-name="${gameTitle.replace(/"/g,'&quot;')}" data-type="${n.resourceType}"
              style="font-size:0.75rem;color:#818cf8;background:none;border:none;cursor:pointer;padding:0;">Edit</button>
          </div>
          <p style="font-size:0.8125rem;color:#e2e8f0;line-height:1.6;margin-bottom:0.5rem;">${n.resourceTitle}</p>
          <p style="font-size:0.875rem;color:#94a3b8;line-height:1.6;white-space:pre-wrap;">${n.note.replace(/</g,'&lt;')}</p>
          ${n.tags.length ? `<div style="display:flex;flex-wrap:wrap;gap:0.375rem;margin-top:0.5rem;">${n.tags.map(t => `<span style="font-size:0.7rem;color:#38bdf8;background-color:rgba(14,165,233,0.1);border:1px solid rgba(14,165,233,0.25);padding:0.1rem 0.4rem;border-radius:9999px;">#${t}</span>`).join('')}</div>` : ''}
          <p style="font-size:0.7rem;color:#334155;margin-top:0.5rem;">${new Date(n.updatedAt).toLocaleDateString()}</p>
        </div>
      `).join('');

      document.querySelectorAll<HTMLElement>('.my-note-edit-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.dispatchEvent(new CustomEvent('open-note-drawer', {
            detail: { url: btn.dataset.url, title: btn.dataset.title, gameSlug: btn.dataset.gameSlug, gameName: btn.dataset.gameName, type: btn.dataset.type }
          }));
        });
      });
    }

    renderMyNotes();
    window.addEventListener('notes-changed', renderMyNotes);
  </script>
</BaseLayout>

<style>
  .prose {
    line-height: 1.85;
    max-width: 680px;
  }
  .prose h2 {
    color: #e2e8f0;
    font-size: 1rem;
    font-weight: 600;
    margin: 2.25rem 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .prose h3 {
    color: #cbd5e1;
    font-size: 0.9375rem;
    font-weight: 600;
    margin: 1.5rem 0 0.375rem;
  }
  /* Paragraphs: indent all, space between */
  .prose p {
    margin-bottom: 0;
    padding-bottom: 1.25rem;
    text-indent: 1.75em;
  }
  /* No indent after a heading — first para of a new section */
  .prose h2 + p,
  .prose h3 + p {
    text-indent: 0;
  }
  /* No indent when paragraph opens with bold (e.g. **Term.** format) */
  .prose p:has(> strong:first-child) {
    text-indent: 0;
  }
  .prose ul {
    margin-left: 1.5rem;
    list-style: disc;
    padding-bottom: 0.875rem;
    text-indent: 0;
  }
  .prose li { margin-bottom: 0.375rem; }
  .prose strong { color: #e2e8f0; }
  .prose a { color: #818cf8; text-decoration: underline; }
</style>

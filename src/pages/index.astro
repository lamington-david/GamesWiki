---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GameCard from '../components/GameCard.astro';

const allGames = await getCollection('games');
const sorted = allGames.sort((a, b) => b.data.playtime - a.data.playtime);

const allGenres = [...new Set(sorted.flatMap(g => g.data.genres))].sort();
const allDesignTags = [...new Set(sorted.flatMap(g => g.data.design_tags))].sort();

const totalResources = sorted.reduce((sum, g) => sum + g.data.resources.length, 0);
---

<BaseLayout title="GamesWiki — Design Reference">
  <div style="max-width: 1280px; margin: 0 auto; padding: 3rem 1.5rem;">

    <!-- Header -->
    <div style="margin-bottom: 3rem;">
      <h1 style="font-size: 2.25rem; font-weight: 800; color: #f1f5f9; letter-spacing: -0.04em; margin-bottom: 0.5rem;">
        Game Design Reference
      </h1>
      <p style="color: #64748b; font-size: 1rem;">
        {sorted.length} games · {totalResources} curated resources — GDC talks, interviews, articles
      </p>
    </div>

    <!-- Search + Filter -->
    <div style="margin-bottom: 2rem; display: flex; flex-direction: column; gap: 1rem;">
      <input
        id="search"
        type="text"
        placeholder="Search games, developers, genres..."
        style="width: 100%; padding: 0.625rem 1rem; background-color: #0f172a; border: 1px solid #1e293b; border-radius: 0.5rem; color: #f1f5f9; font-size: 0.9375rem; outline: none;"
        onfocus="this.style.borderColor='#4f46e5'"
        onblur="this.style.borderColor='#1e293b'"
      />

      <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;">
        <span style="font-size: 0.75rem; color: #475569; white-space: nowrap;">Filter:</span>
        <button class="filter-btn active" data-filter="all" style="padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; border: 1px solid #4f46e5; background-color: #4f46e5; color: white; cursor: pointer;">All</button>
        <button class="filter-btn" data-filter="has-resources" style="padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; border: 1px solid #1e293b; background-color: transparent; color: #94a3b8; cursor: pointer;">Has Resources</button>

        <div style="width: 1px; height: 1rem; background-color: #1e293b; margin: 0 0.25rem;"></div>

        <span style="font-size: 0.75rem; color: #475569; white-space: nowrap;">Sort:</span>
        <button class="sort-btn active" data-sort="playtime" style="padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; border: 1px solid #4f46e5; background-color: #4f46e5; color: white; cursor: pointer;">Most Played</button>
        <button class="sort-btn" data-sort="rating" style="padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; border: 1px solid #1e293b; background-color: transparent; color: #94a3b8; cursor: pointer;">Highest Rated</button>
        <button class="sort-btn" data-sort="title" style="padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; border: 1px solid #1e293b; background-color: transparent; color: #94a3b8; cursor: pointer;">A–Z</button>
        <button class="sort-btn" data-sort="resources" style="padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; border: 1px solid #1e293b; background-color: transparent; color: #94a3b8; cursor: pointer;">Most Resources</button>
      </div>
    </div>

    <!-- Game Grid -->
    <div id="game-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.875rem;">
      {sorted.map((game) => (
        <div
          class="game-item"
          data-title={game.data.title.toLowerCase()}
          data-developer={game.data.developer.toLowerCase()}
          data-genres={game.data.genres.join(' ').toLowerCase()}
          data-design-tags={game.data.design_tags.join(' ').toLowerCase()}
          data-playtime={game.data.playtime}
          data-rating={game.data.steam_rating}
          data-resources={game.data.resources.length}
        >
          <GameCard
            title={game.data.title}
            developer={game.data.developer}
            year={game.data.year}
            genres={game.data.genres}
            playtime={game.data.playtime}
            steam_rating={game.data.steam_rating}
            resourceCount={game.data.resources.length}
            resourceUrls={game.data.resources.map(r => r.url)}
            slug={game.id}
            design_tags={game.data.design_tags}
          />
        </div>
      ))}
    </div>

    <div id="empty-state" style="display: none; text-align: center; padding: 4rem 0; color: #475569;">
      No games match your search.
    </div>
  </div>

  <script>
    const searchInput = document.getElementById('search') as HTMLInputElement;
    const items = document.querySelectorAll('.game-item') as NodeListOf<HTMLElement>;
    const emptyState = document.getElementById('empty-state')!;
    const grid = document.getElementById('game-grid')!;

    let currentFilter = 'all';
    let currentSort = 'playtime';
    let currentSearch = '';

    function applyAll() {
      let visible: HTMLElement[] = [];

      items.forEach(item => {
        const matchesSearch = !currentSearch ||
          item.dataset.title!.includes(currentSearch) ||
          item.dataset.developer!.includes(currentSearch) ||
          item.dataset.genres!.includes(currentSearch) ||
          item.dataset.designTags!.includes(currentSearch);

        const matchesFilter = currentFilter === 'all' ||
          (currentFilter === 'has-resources' && parseInt(item.dataset.resources!) > 0);

        if (matchesSearch && matchesFilter) {
          item.style.display = '';
          visible.push(item);
        } else {
          item.style.display = 'none';
        }
      });

      // Sort
      visible.sort((a, b) => {
        if (currentSort === 'playtime') return parseFloat(b.dataset.playtime!) - parseFloat(a.dataset.playtime!);
        if (currentSort === 'rating') return parseFloat(b.dataset.rating!) - parseFloat(a.dataset.rating!);
        if (currentSort === 'title') return a.dataset.title!.localeCompare(b.dataset.title!);
        if (currentSort === 'resources') return parseInt(b.dataset.resources!) - parseInt(a.dataset.resources!);
        return 0;
      });

      visible.forEach(el => grid.appendChild(el));
      emptyState.style.display = visible.length === 0 ? 'block' : 'none';
    }

    searchInput.addEventListener('input', (e) => {
      currentSearch = (e.target as HTMLInputElement).value.toLowerCase().trim();
      applyAll();
    });

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        currentFilter = (btn as HTMLElement).dataset.filter!;
        document.querySelectorAll('.filter-btn').forEach(b => {
          (b as HTMLElement).style.backgroundColor = 'transparent';
          (b as HTMLElement).style.color = '#94a3b8';
          (b as HTMLElement).style.borderColor = '#1e293b';
        });
        (btn as HTMLElement).style.backgroundColor = '#4f46e5';
        (btn as HTMLElement).style.color = 'white';
        (btn as HTMLElement).style.borderColor = '#4f46e5';
        applyAll();
      });
    });

    document.querySelectorAll('.sort-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        currentSort = (btn as HTMLElement).dataset.sort!;
        document.querySelectorAll('.sort-btn').forEach(b => {
          (b as HTMLElement).style.backgroundColor = 'transparent';
          (b as HTMLElement).style.color = '#94a3b8';
          (b as HTMLElement).style.borderColor = '#1e293b';
        });
        (btn as HTMLElement).style.backgroundColor = '#4f46e5';
        (btn as HTMLElement).style.color = 'white';
        (btn as HTMLElement).style.borderColor = '#4f46e5';
        applyAll();
      });
    });
  </script>
</BaseLayout>

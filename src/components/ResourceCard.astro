---
interface Resource {
  type: string;
  title: string;
  speaker?: string;
  author?: string;
  source: string;
  year?: number;
  summary: string;
  url: string;
  thumbnail?: string;
}

interface Props {
  resource: Resource;
  gameName?: string;
}

const { resource, gameName } = Astro.props;

const typeConfig: Record<string, { label: string; color: string; bg: string; border: string; unreadBorder: string; gradientA: string; gradientB: string }> = {
  gdc_talk:    { label: 'GDC Talk',    color: '#c4b5fd', bg: 'rgba(88,28,135,0.25)',  border: 'rgba(109,40,217,0.4)',  unreadBorder: '#7c3aed', gradientA: '#1e1040', gradientB: '#0d0820' },
  interview:   { label: 'Interview',   color: '#93c5fd', bg: 'rgba(29,78,216,0.25)',  border: 'rgba(37,99,235,0.4)',   unreadBorder: '#2563eb', gradientA: '#0f1e3a', gradientB: '#060e1e' },
  article:     { label: 'Article',     color: '#6ee7b7', bg: 'rgba(5,150,105,0.25)',  border: 'rgba(16,185,129,0.4)', unreadBorder: '#059669', gradientA: '#0a2018', gradientB: '#040e0a' },
  postmortem:  { label: 'Postmortem',  color: '#fcd34d', bg: 'rgba(146,64,14,0.25)', border: 'rgba(217,119,6,0.4)',   unreadBorder: '#d97706', gradientA: '#241608', gradientB: '#100900' },
  video:       { label: 'Video',       color: '#fca5a5', bg: 'rgba(185,28,28,0.25)', border: 'rgba(220,38,38,0.4)',   unreadBorder: '#dc2626', gradientA: '#200808', gradientB: '#0e0404' },
  documentary: { label: 'Documentary', color: '#fdba74', bg: 'rgba(154,52,18,0.25)', border: 'rgba(234,88,12,0.4)',   unreadBorder: '#ea580c', gradientA: '#221008', gradientB: '#0e0603' },
  podcast:     { label: 'Podcast',     color: '#f9a8d4', bg: 'rgba(157,23,77,0.25)', border: 'rgba(219,39,119,0.4)', unreadBorder: '#db2777', gradientA: '#200a14', gradientB: '#0e040a' },
};

const config = typeConfig[resource.type] ?? { label: resource.type, color: '#9ca3af', bg: 'rgba(55,65,81,0.3)', border: 'rgba(75,85,99,0.5)', unreadBorder: '#6b7280', gradientA: '#111827', gradientB: '#030712' };

// Auto-detect YouTube thumbnail
function getYoutubeThumbnail(url: string): string | null {
  const m = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  return m ? `https://img.youtube.com/vi/${m[1]}/mqdefault.jpg` : null;
}

const thumbUrl = resource.thumbnail ?? getYoutubeThumbnail(resource.url);
const domain = (() => { try { return new URL(resource.url).hostname.replace('www.', ''); } catch { return resource.source; } })();
const credit = resource.speaker ?? resource.author;
---

<a
  href={resource.url}
  target="_blank"
  rel="noopener noreferrer"
  class="resource-card-link"
  data-resource-url={resource.url}
  data-resource-type={resource.type}
  data-unread-border={config.unreadBorder}
  style={`display: block; background-color: #111827; border: 1px solid #1f2937; border-left: 3px solid ${config.unreadBorder}; border-radius: 0.5rem; overflow: hidden; text-decoration: none; color: inherit; transition: opacity 0.2s, border-color 0.15s; cursor: pointer; position: relative;`}
>
  <!-- Thumbnail -->
  {thumbUrl ? (
    <div style="position: relative; width: 100%; height: 160px; overflow: hidden; background: #0a0f1a;">
      <img
        src={thumbUrl}
        alt=""
        loading="lazy"
        style="width: 100%; height: 100%; object-fit: cover; display: block;"
        onerror={`this.style.display='none'; this.nextElementSibling.style.display='flex';`}
      />
      <!-- Fallback shown if image errors -->
      <div style={`display: none; position: absolute; inset: 0; background: linear-gradient(135deg, ${config.gradientA}, ${config.gradientB}); align-items: center; justify-content: center; flex-direction: column; gap: 0.375rem;`}>
        <span style={`font-size: 0.75rem; font-weight: 600; color: ${config.color}; letter-spacing: 0.05em; text-transform: uppercase;`}>{config.label}</span>
        <span style="font-size: 0.7rem; color: #475569;">{domain}</span>
      </div>
      <!-- Type badge overlay on thumbnail -->
      <div style="position: absolute; bottom: 0.5rem; left: 0.5rem; display: flex; gap: 0.375rem; align-items: center;">
        <span style={`display: inline-flex; align-items: center; padding: 0.15rem 0.5rem; border-radius: 9999px; font-size: 0.65rem; font-weight: 600; background-color: rgba(0,0,0,0.7); color: ${config.color}; backdrop-filter: blur(4px);`}>
          {config.label}
        </span>
      </div>
    </div>
  ) : (
    <div style={`width: 100%; height: 120px; background: linear-gradient(135deg, ${config.gradientA}, ${config.gradientB}); display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 0.5rem; position: relative;`}>
      <span style={`font-size: 0.8rem; font-weight: 600; color: ${config.color}; letter-spacing: 0.05em; text-transform: uppercase;`}>{config.label}</span>
      <span style="font-size: 0.7rem; color: #475569;">{domain}</span>
      <!-- subtle dot pattern overlay -->
      <div style="position: absolute; inset: 0; opacity: 0.04; background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 20px 20px;"></div>
    </div>
  )}

  <!-- Card body -->
  <div style="padding: 0.875rem;">
    <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.5rem;">
      <div style="display: flex; flex-wrap: wrap; gap: 0.375rem; align-items: center;">
        {gameName && (
          <span style="font-size: 0.7rem; color: #64748b; background-color: #1e293b; padding: 0.125rem 0.5rem; border-radius: 9999px; border: 1px solid #334155; white-space: nowrap;">
            {gameName}
          </span>
        )}
      </div>
      <div style="display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0;">
        {resource.year && <span style="font-size: 0.7rem; color: #475569;">{resource.year}</span>}
        <span class="read-check" style="font-size: 0.75rem; color: #22c55e; display: none;">✓</span>
      </div>
    </div>

    <h3 style="font-size: 0.9375rem; font-weight: 600; color: #f1f5f9; margin-bottom: 0.3rem; line-height: 1.4;">
      {resource.title}
    </h3>

    {credit && (
      <p style="font-size: 0.8rem; color: #9ca3af; margin-bottom: 0.5rem;">{credit} · {resource.source}</p>
    )}
    {!credit && (
      <p style="font-size: 0.8rem; color: #6b7280; margin-bottom: 0.5rem;">{resource.source}</p>
    )}

    <p style="font-size: 0.8125rem; color: #94a3b8; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
      {resource.summary}
    </p>

    <div style="margin-top: 0.625rem; font-size: 0.7rem; color: #475569; display: flex; align-items: center; gap: 0.25rem;">
      <span>↗</span><span>{domain}</span>
    </div>
  </div>
</a>

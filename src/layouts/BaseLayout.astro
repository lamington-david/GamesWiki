---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A design reference wiki for games' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#030712" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="GamesWiki" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
  </head>
  <body style="background-color: #030712; color: #f1f5f9; min-height: 100vh;">

    <nav style="border-bottom: 1px solid #1f2937; background-color: #030712; position: sticky; top: 0; z-index: 50;">
      <div style="max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 56px;">
        <a href="/feed" style="display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: #f1f5f9;">
          <span style="font-size: 1.125rem; font-weight: 700; letter-spacing: -0.025em;">🎮 GamesWiki</span>
        </a>
        <div style="display: flex; align-items: center; gap: 0.25rem;">
          <a href="/feed" style={`font-size: 0.875rem; text-decoration: none; padding: 0.375rem 0.75rem; border-radius: 0.375rem; ${currentPath === '/feed' ? 'color: #f1f5f9; background-color: #1e293b;' : 'color: #9ca3af;'}`}>
            Feed
            <span id="nav-unread" style="display: none; background-color: #4f46e5; color: white; font-size: 0.65rem; padding: 0.1rem 0.375rem; border-radius: 9999px; margin-left: 0.25rem; vertical-align: middle; line-height: 1.4;"></span>
          </a>
          <a href="/" style={`font-size: 0.875rem; text-decoration: none; padding: 0.375rem 0.75rem; border-radius: 0.375rem; ${currentPath === '/' ? 'color: #f1f5f9; background-color: #1e293b;' : 'color: #9ca3af;'}`}>
            Games
          </a>
          <a href="/notes" style={`font-size: 0.875rem; text-decoration: none; padding: 0.375rem 0.75rem; border-radius: 0.375rem; ${currentPath === '/notes' ? 'color: #f1f5f9; background-color: #1e293b;' : 'color: #9ca3af;'}`}>
            Notes
            <span id="nav-notes-count" style="display: none; background-color: #0891b2; color: white; font-size: 0.65rem; padding: 0.1rem 0.375rem; border-radius: 9999px; margin-left: 0.25rem; vertical-align: middle; line-height: 1.4;"></span>
          </a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer style="border-top: 1px solid #1f2937; margin-top: 4rem; padding: 2rem 1.5rem; text-align: center;">
      <p style="font-size: 0.875rem; color: #4b5563;">Design reference wiki — built from your Steam library</p>
    </footer>

    <!-- Note nudge toast -->
    <div id="note-nudge" style="display: none; position: fixed; bottom: 1.25rem; left: 50%; transform: translateX(-50%); z-index: 60; background-color: #1e293b; border: 1px solid #334155; border-radius: 0.625rem; padding: 0.75rem 1rem; display: flex; align-items: center; gap: 0.75rem; box-shadow: 0 4px 24px rgba(0,0,0,0.5); min-width: 260px; max-width: 90vw;">
      <span style="font-size: 0.875rem; color: #cbd5e1; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" id="nudge-label">Add a note?</span>
      <button id="nudge-add-btn" style="font-size: 0.8rem; font-weight: 600; color: #818cf8; background: none; border: none; cursor: pointer; padding: 0; white-space: nowrap;">✏️ Add note</button>
      <button id="nudge-close-btn" style="font-size: 0.8rem; color: #475569; background: none; border: none; cursor: pointer; padding: 0; margin-left: 0.25rem;">✕</button>
    </div>

    <!-- Note drawer backdrop -->
    <div id="drawer-backdrop" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 70; backdrop-filter: blur(2px);"></div>

    <!-- Note drawer -->
    <div id="note-drawer" style="display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 80; background-color: #0f172a; border-top: 1px solid #1e293b; border-radius: 1rem 1rem 0 0; padding: 0 1.25rem 1.25rem; max-height: 85vh; overflow-y: auto; box-shadow: 0 -8px 40px rgba(0,0,0,0.6);">
      <!-- Handle -->
      <div style="display: flex; justify-content: center; padding: 0.75rem 0 0.5rem;">
        <div style="width: 2.5rem; height: 0.25rem; background-color: #334155; border-radius: 9999px;"></div>
      </div>
      <!-- Header -->
      <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; margin-bottom: 1rem;">
        <div style="flex: 1; min-width: 0;">
          <p style="font-size: 0.7rem; color: #475569; margin-bottom: 0.2rem; text-transform: uppercase; letter-spacing: 0.05em;" id="drawer-type-label">Note</p>
          <p style="font-size: 0.9rem; font-weight: 600; color: #e2e8f0; line-height: 1.3; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" id="drawer-resource-title">Resource</p>
        </div>
        <button id="drawer-close" style="color: #475569; background: none; border: none; cursor: pointer; font-size: 1.25rem; padding: 0; flex-shrink: 0;">✕</button>
      </div>
      <!-- Textarea -->
      <textarea
        id="drawer-textarea"
        placeholder="What did you notice? Use #tags to categorise..."
        style="width: 100%; box-sizing: border-box; min-height: 140px; background-color: #1e293b; border: 1px solid #334155; border-radius: 0.5rem; padding: 0.75rem; color: #f1f5f9; font-size: 0.9375rem; line-height: 1.6; resize: vertical; outline: none; font-family: inherit;"
      ></textarea>
      <!-- Tag pills -->
      <div id="drawer-tags" style="display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.625rem; min-height: 1.5rem;"></div>
      <!-- Actions -->
      <div style="display: flex; gap: 0.625rem; margin-top: 1rem;">
        <button id="drawer-save" style="flex: 1; padding: 0.625rem; background-color: #4f46e5; color: white; border: none; border-radius: 0.5rem; font-size: 0.9375rem; font-weight: 600; cursor: pointer;">Save</button>
        <button id="drawer-delete" style="display: none; padding: 0.625rem 1rem; background-color: transparent; color: #f87171; border: 1px solid #991b1b; border-radius: 0.5rem; font-size: 0.9375rem; cursor: pointer;">Delete</button>
      </div>
    </div>

  </body>
  <script>
    import { getNotes, getNote, saveNote, deleteNote, extractTags } from '../scripts/notes';

    // ── Service worker ──────────────────────────────────────────────
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js').catch(() => {}));
    }

    // ── Read tracking ───────────────────────────────────────────────
    const READS_KEY = 'gw:reads';
    function getReads() {
      try { return JSON.parse(localStorage.getItem(READS_KEY) || '{}'); } catch { return {}; }
    }
    function markRead(url: string) {
      const reads = getReads();
      if (!reads[url]) { reads[url] = Date.now(); localStorage.setItem(READS_KEY, JSON.stringify(reads)); }
    }

    function applyReadStates() {
      const reads = getReads();
      document.querySelectorAll<HTMLElement>('[data-resource-url]').forEach(card => {
        const url = card.dataset.resourceUrl!;
        const isRead = !!reads[url];
        const unreadBorder = card.dataset.unreadBorder || '#4f46e5';
        const check = card.querySelector<HTMLElement>('.read-check');
        card.style.opacity = isRead ? '0.45' : '1';
        card.style.borderLeftColor = isRead ? '#1f2937' : unreadBorder;
        if (check) check.style.display = isRead ? 'inline' : 'none';
      });
      document.querySelectorAll<HTMLElement>('[data-resource-urls]').forEach(card => {
        try {
          const urls: string[] = JSON.parse(card.dataset.resourceUrls!);
          const unread = urls.filter(u => !reads[u]).length;
          const badge = card.querySelector<HTMLElement>('.unread-badge');
          if (badge && urls.length > 0) {
            badge.textContent = unread === 0 ? 'All read ✓' : `${unread} unread`;
            badge.style.color = unread === 0 ? '#22c55e' : '#6366f1';
          }
        } catch {}
      });
      const navUnread = document.getElementById('nav-unread');
      if (navUnread) {
        const allCards = document.querySelectorAll('[data-resource-url]');
        if (allCards.length > 0) {
          const n = Array.from(allCards).filter(c => !reads[(c as HTMLElement).dataset.resourceUrl!]).length;
          navUnread.textContent = n > 0 ? String(n) : '';
          navUnread.style.display = n > 0 ? 'inline-block' : 'none';
        }
      }
    }

    // ── Note indicators ─────────────────────────────────────────────
    function applyNoteIndicators() {
      const notes = getNotes();
      document.querySelectorAll<HTMLElement>('[data-note-dot]').forEach(dot => {
        const url = dot.dataset.noteDot!;
        dot.style.display = notes[url] ? 'inline-block' : 'none';
      });
      const navCount = document.getElementById('nav-notes-count');
      if (navCount) {
        const n = Object.keys(getNotes()).filter(u => getNotes()[u]?.note?.trim()).length;
        navCount.textContent = n > 0 ? String(n) : '';
        navCount.style.display = n > 0 ? 'inline-block' : 'none';
      }
    }

    // ── Drawer ──────────────────────────────────────────────────────
    const drawer = document.getElementById('note-drawer')!;
    const backdrop = document.getElementById('drawer-backdrop')!;
    const textarea = document.getElementById('drawer-textarea') as HTMLTextAreaElement;
    const tagsEl = document.getElementById('drawer-tags')!;
    const titleEl = document.getElementById('drawer-resource-title')!;
    const typeLabelEl = document.getElementById('drawer-type-label')!;
    const saveBtn = document.getElementById('drawer-save')!;
    const deleteBtn = document.getElementById('drawer-delete')!;
    const closeBtn = document.getElementById('drawer-close')!;

    let drawerContext: { url: string; title: string; gameSlug: string; gameName: string; type: string } | null = null;

    function openDrawer(ctx: typeof drawerContext) {
      drawerContext = ctx;
      const existing = getNote(ctx!.url);
      titleEl.textContent = ctx!.title;
      typeLabelEl.textContent = ctx!.type.replace(/_/g, ' ');
      textarea.value = existing?.note ?? '';
      renderTagPills(extractTags(textarea.value));
      deleteBtn.style.display = existing ? 'block' : 'none';
      drawer.style.display = 'block';
      backdrop.style.display = 'block';
      requestAnimationFrame(() => textarea.focus());
    }

    function closeDrawer() {
      drawer.style.display = 'none';
      backdrop.style.display = 'none';
      drawerContext = null;
    }

    function renderTagPills(tags: string[]) {
      tagsEl.innerHTML = tags.map(t =>
        `<span style="display:inline-flex;align-items:center;padding:0.15rem 0.5rem;border-radius:9999px;font-size:0.7rem;font-weight:500;background-color:rgba(14,165,233,0.15);color:#38bdf8;border:1px solid rgba(14,165,233,0.3);">#${t}</span>`
      ).join('');
    }

    textarea.addEventListener('input', () => renderTagPills(extractTags(textarea.value)));

    saveBtn.addEventListener('click', () => {
      if (!drawerContext) return;
      const note = textarea.value.trim();
      if (note) {
        saveNote(drawerContext.url, {
          note,
          gameSlug: drawerContext.gameSlug ?? '',
          gameName: drawerContext.gameName ?? '',
          resourceTitle: drawerContext.title,
          resourceType: drawerContext.type,
        });
      }
      closeDrawer();
      applyNoteIndicators();
    });

    deleteBtn.addEventListener('click', () => {
      if (!drawerContext) return;
      deleteNote(drawerContext.url);
      closeDrawer();
      applyNoteIndicators();
    });

    closeBtn.addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);

    document.addEventListener('open-note-drawer', (e: Event) => {
      const detail = (e as CustomEvent).detail;
      openDrawer(detail);
    });

    // ── Note nudge ──────────────────────────────────────────────────
    const nudge = document.getElementById('note-nudge')!;
    const nudgeLabel = document.getElementById('nudge-label')!;
    const nudgeAddBtn = document.getElementById('nudge-add-btn')!;
    const nudgeCloseBtn = document.getElementById('nudge-close-btn')!;
    let nudgeCtx: typeof drawerContext = null;
    let nudgeTimer: ReturnType<typeof setTimeout> | null = null;

    function showNudge(ctx: typeof drawerContext) {
      nudgeCtx = ctx;
      nudgeLabel.textContent = ctx!.title;
      nudge.style.display = 'flex';
      if (nudgeTimer) clearTimeout(nudgeTimer);
      nudgeTimer = setTimeout(hideNudge, 5000);
    }
    function hideNudge() { nudge.style.display = 'none'; nudgeCtx = null; }
    nudgeAddBtn.addEventListener('click', () => { if (nudgeCtx) openDrawer(nudgeCtx); hideNudge(); });
    nudgeCloseBtn.addEventListener('click', hideNudge);

    // ── Pencil button + card link clicks ────────────────────────────
    const isFirefox = navigator.userAgent.toLowerCase().includes('firefox');
    const readerTypes = new Set(['article', 'postmortem']);

    document.addEventListener('click', e => {
      // Note button (capture phase handles pencil clicks inside <a> tags)
      const noteBtn = (e.target as Element).closest<HTMLElement>('[data-note-trigger]');
      if (noteBtn) {
        e.preventDefault();
        e.stopImmediatePropagation();
        openDrawer({
          url: noteBtn.dataset.noteUrl!,
          title: noteBtn.dataset.noteTitle!,
          gameSlug: noteBtn.dataset.noteGameSlug ?? '',
          gameName: noteBtn.dataset.noteGameName ?? '',
          type: noteBtn.dataset.noteType ?? 'resource',
        });
        return;
      }

      // Resource card click: mark read + maybe nudge
      const card = (e.target as Element).closest<HTMLElement>('[data-resource-url]');
      if (!card) return;
      const url = card.dataset.resourceUrl!;
      const type = card.dataset.resourceType;
      markRead(url);
      setTimeout(applyReadStates, 50);

      if (!getNote(url)) {
        showNudge({
          url,
          title: card.dataset.resourceTitle ?? 'this resource',
          gameSlug: card.dataset.gameSlug ?? '',
          gameName: card.dataset.gameName ?? '',
          type: type ?? 'resource',
        });
      }

      if (isFirefox && type && readerTypes.has(type)) {
        e.preventDefault();
        window.open('about:reader?url=' + encodeURIComponent(url), '_blank');
      }
    }, true);

    window.addEventListener('storage', e => { if (e.key === READS_KEY) applyReadStates(); });
    window.addEventListener('notes-changed', () => { applyNoteIndicators(); });

    document.addEventListener('DOMContentLoaded', () => { applyReadStates(); applyNoteIndicators(); });
  </script>
</html>
